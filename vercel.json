{
  "headers": [{
    "source": "/(.*)",
    "headers": [
      { 
        "key": "Content-Security-Policy", 
        "value": "frame-ancestors 'none'; form-action 'self' https://script.google.com" 
      },
      { 
        "key": "X-Frame-Options", 
        "value": "DENY" 
      },
      { 
        "key": "Referrer-Policy", 
        "value": "strict-origin-when-cross-origin" 
      },
      {
        "key": "Permissions-Policy",
        "value": "geolocation=(), microphone=(), camera=()"
      }
    ]
  }]
}
